<Window x:Class="PasteIt.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PasteIt"
        Width="700" Height="500"
        MinWidth="560" MinHeight="380"
        Background="{StaticResource PageBgBrush}"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="170" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBgBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
            <DockPanel LastChildFill="False" Margin="0,20,0,16">
                <TextBlock DockPanel.Dock="Top"
                           Text="PasteIt" FontSize="17" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           Margin="18,0,0,20" />

                <StackPanel DockPanel.Dock="Top">
                    <Button x:Name="BtnHistory" Content="History" Click="BtnHistory_Click" Tag="active" />
                    <Button x:Name="BtnSettings" Content="Settings" Click="BtnSettings_Click" />
                </StackPanel>

                <TextBlock DockPanel.Dock="Bottom" Text="v1.0.0"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="11" Margin="18,0,0,0" />
            </DockPanel>
        </Border>

        <!-- Content -->
        <Grid Grid.Column="1" Margin="24,20,24,20">

            <!-- HISTORY -->
            <Grid x:Name="HistoryView" Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="History"
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           Margin="0,0,0,14" />

                <Border Grid.Row="1"
                        Background="{StaticResource CardBgBrush}"
                        CornerRadius="8"
                        Padding="12,10"
                        Margin="0,0,0,12"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1">
                    <TextBox x:Name="TxtHistorySearch"
                             TextChanged="SearchHistory_TextChanged"
                             BorderThickness="0"
                             Background="Transparent"
                             FontSize="12.5"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             ToolTip="Search history"
                             Text=""
                             />
                </Border>

                <TextBlock x:Name="EmptyHistoryLabel" Grid.Row="2"
                           Text="Nothing here yet. Paste something with Ctrl+Shift+V or the right-click menu."
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="13" TextWrapping="Wrap"
                           VerticalAlignment="Center" HorizontalAlignment="Center"
                           Visibility="Collapsed" />

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                              Padding="0,0,4,0">
                    <ItemsControl x:Name="HistoryList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource CardBgBrush}"
                                        CornerRadius="8" Padding="14,11"
                                        Margin="0,0,0,6"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        Cursor="Hand"
                                        MouseLeftButtonUp="HistoryCard_Click">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <!-- Type label -->
                                        <Border Grid.Column="0" Grid.Row="0" Grid.RowSpan="2"
                                                Background="{StaticResource InputBgBrush}"
                                                CornerRadius="5"
                                                Padding="8,6" Margin="0,0,11,0"
                                                VerticalAlignment="Top">
                                            <TextBlock Text="{Binding TypeLabel}"
                                                       FontSize="11" FontWeight="Medium"
                                                       Foreground="{StaticResource TextSecondaryBrush}" />
                                        </Border>

                                        <!-- Filename -->
                                        <TextBlock Grid.Column="1" Grid.Row="0"
                                                   Text="{Binding FileName}"
                                                   FontSize="13" FontWeight="Medium"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   TextTrimming="CharacterEllipsis" />

                                        <!-- Meta -->
                                        <TextBlock Grid.Column="1" Grid.Row="1"
                                                   FontSize="11.5"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   Margin="0,2,0,0">
                                            <Run Text="{Binding TimeAgo, Mode=OneWay}" />
                                            <Run Text=" · " />
                                            <Run Text="{Binding FileSize, Mode=OneWay}" />
                                        </TextBlock>

                                        <!-- Actions -->
                                        <StackPanel Grid.Column="2" Grid.Row="0" Grid.RowSpan="2"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <Border VerticalAlignment="Center" Cursor="Hand"
                                                    MouseLeftButtonUp="CopyButton_Click"
                                                    Background="Transparent"
                                                    Padding="6,4">
                                                <TextBlock Text="Copy" FontSize="12"
                                                           Foreground="{StaticResource AccentBrush}" />
                                            </Border>
                                            <Border VerticalAlignment="Center" Cursor="Hand"
                                                    MouseLeftButtonUp="OpenButton_Click"
                                                    Background="Transparent"
                                                    Padding="6,4">
                                                <TextBlock Text="Open" FontSize="12"
                                                           Foreground="{StaticResource AccentBrush}" />
                                            </Border>
                                            <Border VerticalAlignment="Center" Cursor="Hand"
                                                    MouseLeftButtonUp="RevealButton_Click"
                                                    Background="Transparent"
                                                    Padding="6,4">
                                                <TextBlock Text="Reveal" FontSize="12"
                                                           Foreground="{StaticResource AccentBrush}" />
                                            </Border>
                                            <Border VerticalAlignment="Center" Cursor="Hand"
                                                    MouseLeftButtonUp="DeleteButton_Click"
                                                    Background="Transparent"
                                                    Padding="6,4">
                                                <TextBlock Text="Delete" FontSize="12"
                                                           Foreground="{StaticResource DangerBrush}" />
                                            </Border>
                                        </StackPanel>

                                        <!-- Preview -->
                                        <Border Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="2"
                                                Visibility="{Binding PreviewVisibility}"
                                                Background="{StaticResource InputBgBrush}"
                                                CornerRadius="5" Padding="10,8"
                                                Margin="0,9,0,0">
                                            <TextBlock Text="{Binding PreviewText}"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="11.5" FontFamily="Consolas"
                                                       TextWrapping="Wrap" MaxHeight="100" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- SETTINGS -->
            <Grid x:Name="SettingsView" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Settings"
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           Margin="0,0,0,14" />

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <!-- History limit -->
                        <Border Background="{StaticResource CardBgBrush}" CornerRadius="8"
                                Padding="14,12" Margin="0,0,0,6"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Left">
                                    <TextBlock Text="History limit" FontSize="13" FontWeight="Medium"
                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                    <TextBlock Text="Max entries to keep" FontSize="11.5"
                                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0" />
                                </StackPanel>
                                <TextBox x:Name="TxtMaxHistory" DockPanel.Dock="Right"
                                         Width="56" VerticalAlignment="Center" HorizontalAlignment="Right"
                                         TextAlignment="Center" />
                            </DockPanel>
                        </Border>

                        <!-- Filename prefix -->
                        <Border Background="{StaticResource CardBgBrush}" CornerRadius="8"
                                Padding="14,12" Margin="0,0,0,6"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Left">
                                    <TextBlock Text="Filename prefix" FontSize="13" FontWeight="Medium"
                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                    <TextBlock Text="e.g. clipboard_2026-03-04_001.py" FontSize="11.5"
                                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0" />
                                </StackPanel>
                                <TextBox x:Name="TxtFilenamePrefix" DockPanel.Dock="Right"
                                         Width="110" VerticalAlignment="Center" HorizontalAlignment="Right" />
                            </DockPanel>
                        </Border>

                        <!-- Default save location -->
                        <Border Background="{StaticResource CardBgBrush}" CornerRadius="8"
                                Padding="14,12" Margin="0,0,0,6"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Left" MaxWidth="280">
                                    <TextBlock Text="Default save location" FontSize="13" FontWeight="Medium"
                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                    <TextBlock Text="Empty = current Explorer folder" FontSize="11.5"
                                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0" />
                                </StackPanel>
                                <TextBox x:Name="TxtDefaultSaveLocation" DockPanel.Dock="Right"
                                         Width="170" VerticalAlignment="Center" HorizontalAlignment="Right" />
                            </DockPanel>
                        </Border>

                        <Border Background="{StaticResource CardBgBrush}" CornerRadius="8"
                                Padding="14,12" Margin="0,0,0,6"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Left" MaxWidth="280">
                                    <TextBlock Text="FFmpeg path" FontSize="13" FontWeight="Medium"
                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                    <TextBlock Text="Optional. Needed for converting pasted videos to other formats." FontSize="11.5"
                                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0" TextWrapping="Wrap" />
                                </StackPanel>
                                <TextBox x:Name="TxtFfmpegPath" DockPanel.Dock="Right"
                                         Width="170" VerticalAlignment="Center" HorizontalAlignment="Right" />
                            </DockPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- Actions -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                    <Border Cursor="Hand" MouseLeftButtonUp="ClearHistory_Click"
                            Padding="12,7" Margin="0,0,10,0">
                        <TextBlock Text="Clear history" FontSize="12.5"
                                   Foreground="{StaticResource DangerBrush}" />
                    </Border>

                    <Border Cursor="Hand" MouseLeftButtonUp="SaveSettings_Click"
                            Background="{StaticResource AccentBrush}"
                            CornerRadius="6" Padding="16,7">
                        <TextBlock Text="Save" FontSize="12.5" Foreground="White" />
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>

    <!-- Sidebar nav buttons -->
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="18,8" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}" CornerRadius="6" Margin="6,1">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E2E3E8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Tag" Value="active">
                    <Setter Property="Background" Value="#DCDDE2" />
                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                    <Setter Property="FontWeight" Value="Medium" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
</Window>
